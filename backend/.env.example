# Hugging Face API Token
# Get from: https://huggingface.co/settings/tokens
# Role: Read
HUGGINGFACE_API_KEY=hf_...

# Pinata IPFS - used for encrypted file pinning
# Get from: https://app.pinata.cloud/developers/api-keys
PINATA_API_KEY=your_pinata_api_key
PINATA_SECRET_API_KEY=your_pinata_secret_key
PINATA_JWT=your_pinata_jwt_token

# Encryption key (32 bytes base64-encoded)
# Generate with: python3 -c "import secrets,base64; print(base64.b64encode(secrets.token_bytes(32)).decode())"
ENCRYPTION_KEY=your_base64_encoded_32_byte_key

# CORS allowed origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# Optional: running environment
ENV=development

# ===========================
# x402 Payment Protocol
# ===========================
# EVM wallet address to receive USDC payments on Base network
# Get a free wallet from Coinbase or generate with: cast wallet new
PAY_TO_ADDRESS=0xYourEVMWalletAddress

# Network: Base Sepolia testnet (eip155:84532) or Base mainnet (eip155:8453)
X402_NETWORK=eip155:84532

# Set to "false" to bypass payment requirements during local development
X402_ENABLED=true
